RESALE_AGENT_ENV=development
RESALE_AGENT_API_BASE_URL=http://localhost:8000/api/v1
RESALE_AGENT_DB_PATH=./data/resale.db
RESALE_AGENT_UPLOAD_DIR=./uploads

# 可选：配置后图片识别会调用 OpenAI 兼容多模态接口；失败时自动降级到本地识别初稿
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_VISION_MODEL=gpt-4.1-mini
OPENAI_TEXT_MODEL=gpt-4.1-mini
